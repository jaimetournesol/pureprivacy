# PurePrivacy LiveKit SFU config.
# Tor-only mode: TCP fallback only, since UDP cannot traverse a hidden service.

port: 7880
bind_addresses:
  - 0.0.0.0

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50019
  use_external_ip: false
  # Force TCP relay so the WebRTC media path can ride Tor's hidden-service
  # tunnel.  This adds latency (~100-300 ms above clearnet) but keeps the
  # whole system reachable without exposing a public IP.
  #
  # Loopback candidates (the container's 127.0.0.1) leak the fact of a
  # loopback interface to peers and add useless ICE attempts that always
  # fail.  Disable.
  enable_loopback_candidate: false

keys:
  ${LIVEKIT_API_KEY}: ${LIVEKIT_API_SECRET}

logging:
  level: info
  json: false

# Disable auto-update / telemetry.
turn:
  enabled: false

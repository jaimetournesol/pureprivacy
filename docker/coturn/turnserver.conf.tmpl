# PurePrivacy coturn configuration.  Built for TCP-only relay over Tor.

# Client-facing listening ports.
listening-port=3478
tls-listening-port=5349

# Relay range.  Each active TURN allocation pins one port from this
# range for ~15 minutes (default lifetime), so 40 ports ≈ 40 concurrent
# 1:1 calls — well above what a small-group appliance needs in
# practice and with enough headroom that leaked / not-yet-GC'd
# allocations don't block call setup.
#
# THIS RANGE MUST EXACTLY MATCH the HiddenServicePort entries in
# docker/tor/torrc.  Tor cannot wildcard-map a port range, so every
# port in here also needs an explicit line over there.  If you change
# the range, change both files together.
min-port=49152
max-port=49191

# We don't have a real public IP — coturn's external-ip is the .onion
# hostname so client SDP advertises the right address.
external-ip=${SERVER_NAME}

# Authentication: long-term shared secret, the same one Synapse advertises
# to clients via /voip/turnServer.  Synapse signs short-lived TURN credentials
# with this secret.
use-auth-secret
static-auth-secret=${TURN_SHARED_SECRET}

# Realm matches the homeserver name so credentials are scoped correctly.
realm=${SERVER_NAME}

# Hard mode: refuse plain UDP because Tor cannot tunnel it.
no-udp
no-udp-relay

# Defensive defaults.
no-multicast-peers
no-cli
no-stdout-log
fingerprint
total-quota=200
user-quota=20

# Logging straight to stderr for `docker logs`.
log-file=stdout
verbose

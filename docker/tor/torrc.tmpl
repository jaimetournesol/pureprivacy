# MatrixRTC (only useful when the `voice` profile is active; harmless otherwise).
HiddenServicePort 7880  ${PUREPRIVACY_NET_PREFIX}.12:7880
HiddenServicePort 7881  ${PUREPRIVACY_NET_PREFIX}.12:7881
HiddenServicePort 8082  ${PUREPRIVACY_NET_PREFIX}.14:8080
# WSS-terminated path to LiveKit through synapse-fed-proxy.  Element
# Call won't accept ws:// for SFU connections, so fed-proxy terminates
# TLS with the onion self-signed cert and reverse-proxies the WS
# upgrade to livekit:7880.  Phones connect to wss://${ONION}:7443
# (URL handed out by lk-jwt's JWT after the override in its entrypoint).
HiddenServicePort 7443  ${PUREPRIVACY_NET_PREFIX}.13:7443
# udprelay shim (cross-instance voice spike; harmless if the udprelay
# compose profile isn't active).  Peer's udprelay dials in here via
# SOCKS5 and ships framed UDP back and forth.  The shim shares
# coturn's network namespace (Phase 1b), so port 7001 lands on
# coturn's IP — not a separate udprelay address.
HiddenServicePort 7001  ${PUREPRIVACY_NET_PREFIX}.11:7001

Log notice stdout
SafeLogging 1

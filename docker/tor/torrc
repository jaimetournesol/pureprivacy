# PurePrivacy tor configuration.
# Two roles: (1) host the hidden service for inbound client/federation
# traffic, (2) act as a SOCKS proxy for Synapse's outbound federation.

User tor
DataDirectory /var/lib/tor
PidFile /var/lib/tor/tor.pid

# SOCKS proxy reachable from other containers on the pureprivacy_net.
SocksPort 0.0.0.0:9050

# Hidden service.  Maps the .onion to the in-network services.
HiddenServiceDir /var/lib/tor/pureprivacy
HiddenServiceVersion 3
HiddenServicePort 80   172.30.0.10:8008
HiddenServicePort 8008 172.30.0.10:8008
HiddenServicePort 8448 172.30.0.10:8008
HiddenServicePort 3478 172.30.0.11:3478
HiddenServicePort 5349 172.30.0.11:5349
# Coturn TCP relay range — every active TURN allocation pins one
# port in here for ~15 min.  40 ports ≈ 40 concurrent calls; well
# above what a small-group v0.1 appliance needs and with headroom for
# slow GC of expired allocations.  THIS RANGE MUST EXACTLY MATCH
# `min-port` / `max-port` in docker/coturn/turnserver.conf.tmpl —
# Tor cannot wildcard-map a range.  If you change one file, change the
# other.

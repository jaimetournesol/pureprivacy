# PurePrivacy configuration.  Everything in here is optional — defaults
# work for a single-host install.  You only need a .env if you want to:
#   - resolve a port conflict on the host (loopback wizard / loopback MCP),
#   - tune the MCP token grace window.

# Compose project name. Don't change this unless you know why — it isolates
# the stack from any other Docker projects on the host.
COMPOSE_PROJECT_NAME=pureprivacy

# Loopback port for the first-boot wizard. Bound to 127.0.0.1 only.
WIZARD_PORT=8088

# Loopback port for the MCP server. Bound to 127.0.0.1 only by default.
# To let a remote agent reach it, point this to a Tor onion service or a
# tunnel — never expose it publicly without a real reverse proxy + TLS.
MCP_PORT=8089

# Coturn (TURN/STUN for 1:1 voice). Only needed for voice calls; safe to leave.
COTURN_PORT=3478

# Synapse internal port (only exposed inside the docker network — leave alone).
SYNAPSE_PORT=8008

# Postgres internal port (only exposed inside the docker network — leave alone).
POSTGRES_PORT=5432

# Image tags. Pinning is intentional — bump together via release PRs.
SYNAPSE_IMAGE_TAG=v1.122.0
POSTGRES_IMAGE_TAG=16-alpine
COTURN_IMAGE_TAG=4.6.2-r12
TOR_IMAGE_TAG=0.4.8.13

# Registry + tag for the local-built images (init, tor, privoxy, synapse,
# coturn, wizard, mcp, plus the voice-profile sidecars).  Defaults pull
# from the upstream GHCR registry — fork users can override the registry
# to publish under their own org without touching docker-compose.yml.
#
# `pureprivacy up` pulls these images by default (~1 min on first run).
# Run `pureprivacy up --dev` to force a local build instead — useful when
# editing Dockerfiles or testing un-released changes.
# PUREPRIVACY_REGISTRY=ghcr.io/jaimetournesol
# PUREPRIVACY_IMAGE_TAG=0.1.0

# ---------------------------------------------------------------------------
# MCP token rotation grace window.
# ---------------------------------------------------------------------------

# How long the previous MCP bearer token stays valid after rotation, in
# seconds.  Default 600 (10 minutes) gives agents time to migrate to the
# new token.  Set to 1 to effectively disable the grace window.
# MCP_TOKEN_GRACE_SECONDS=600

# Force LF line endings for files that are read by Linux containers or POSIX
# shells.  Without this, Windows clones with the default core.autocrlf=true
# pick up CRLF on every shell script and Dockerfile, and the kernel inside
# the container fails to exec the shebang line:
#
#     env: 'bash\r': No such file or directory
#
# This bites every PurePrivacy container that runs an entrypoint script (init,
# tor, coturn, synapse, lk-jwt, synapse-fed-proxy) — the appliance literally
# cannot boot on a fresh Windows clone without this file.
*.sh           text eol=lf
*.bash         text eol=lf
Dockerfile     text eol=lf
Dockerfile.*   text eol=lf
*.dockerfile   text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.cfg          text eol=lf
*.conf         text eol=lf
*.j2           text eol=lf

# Files without an extension that are tracked as scripts.
scripts/pureprivacy text eol=lf

# Binary files — never normalize.
*.png  binary
*.jpg  binary
*.gif  binary
